---
layout: null
permalink: /sitemap.xml
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for page in site.pages %}
    {% unless page.sitemap == false or page.url == "/sitemap.xml" or page.name == "404.html" or page.url contains ".json" %}
    {% assign page_lastmod = page.last_modified_at | default: page.date %}
  <url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    {% if page_lastmod %}<lastmod>{{ page_lastmod | date: "%Y-%m-%d" }}</lastmod>{% endif %}
    <changefreq>{% if page.url == "/" %}monthly{% elsif page.url == "/blog/" or page.url == "/en/blog/" %}weekly{% elsif page.url == "/privacy/" %}yearly{% else %}monthly{% endif %}</changefreq>
    <priority>{% if page.url == "/" %}1.00{% elsif page.url == "/blog/" or page.url == "/en/blog/" %}0.90{% elsif page.url == "/privacy/" %}0.30{% else %}0.50{% endif %}</priority>
  </url>
    {% endunless %}
  {% endfor %}
  {% for post in site.posts %}
    {% unless post.sitemap == false %}
    {% assign post_lastmod = post.last_modified_at | default: post.date %}
  <url>
    <loc>{{ site.url }}{{ post.url }}</loc>
    {% if post_lastmod %}<lastmod>{{ post_lastmod | date: "%Y-%m-%d" }}</lastmod>{% endif %}
    <changefreq>monthly</changefreq>
    <priority>0.70</priority>
  </url>
    {% endunless %}
  {% endfor %}
</urlset>
